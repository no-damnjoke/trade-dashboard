# Runtime
PORT=3001
NODE_ENV=production

# Production safety
ENABLE_DEV_ROUTES=false
DISABLE_VELOCITY_POLLING=false
DISABLE_HEADLINE_POLLING=false
DISABLE_FX_SETUP_POLLING=false
DISABLE_OPPORTUNITY_POLLING=false

# Headlines
FIRSTSQUAWK_TG_CHANNEL=firstsquaw
FINNHUB_KEY=
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
TWITTER_USER=
TWITTER_PASS=
TWITTER_EMAIL=

# AI provider
AI_PROVIDER=deterministic
AI_BRIDGE_BASE_URL=http://127.0.0.1:8317/v1
AI_BRIDGE_API_KEY=
AI_HEADLINE_MODEL=gpt-4o-mini
AI_FX_SETUP_MODEL=gpt-4o-mini
AI_OPPORTUNITY_MODEL=gpt-4o-mini
AI_HEADLINE_REASONING_EFFORT=low
AI_FX_SETUP_REASONING_EFFORT=medium
AI_OPPORTUNITY_REASONING_EFFORT=low
AI_TIMEOUT_MS=12000
AI_MAX_RETRIES=1
AI_HEADLINE_MIN_CONFIDENCE=60
AI_HEADLINE_ALERT_MIN_CONFIDENCE=65
AI_FX_SETUP_MIN_CONFIDENCE=60
AI_OPPORTUNITY_MIN_CONFIDENCE=60
